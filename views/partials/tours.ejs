<section id="combo" class="section tours-section">
  <div class="container">
    <div class="tours-header">
      <div>
        <div class="section-eyebrow" style="justify-content:flex-start; margin-bottom:16px;">
          <div class="line l" style="width:40px"></div>
          <span>Đề xuất cho bạn</span>
        </div>
        <h2 class="section-title" style="text-align:left; margin-bottom:0;">Tour & Combo Nổi Bật</h2>
      </div>

      <div class="tours-nav">
        <button class="circle-btn" id="tours-prev" aria-label="Trước">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="circle-btn solid" id="tours-next" aria-label="Sau">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <div class="tours-track-wrap" id="tours-track-wrap">
      <div class="tours-track" id="tours-track">
        <% tours.forEach(tour => { %>
          <div class="tour-card" onclick="window.location.href='/tour-detail/<%= tour._id %>'" style="cursor:pointer;">
            <div class="tour-img-wrap">
              <img src="<%= tour.image %>" alt="<%= tour.name %>" loading="lazy" />
              <% if (tour.badge) { %>
                <div class="tour-badge" style="background-color:<%= tour.badgeColor %>"><%= tour.badge %></div>
              <% } %>
              <div class="tour-duration">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <%= tour.duration %>
              </div>
            </div>

            <div class="tour-body">
              <div class="tour-loc">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <%= tour.location %>
              </div>
              <h3 class="tour-name"><%= tour.name %></h3>

              <div class="tour-rating">
                <div class="stars">
                  <% for (let s = 1; s <= 5; s++) { %>
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="<%= s <= Math.round(tour.rating) ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <% } %>
                </div>
                <span class="count"><%= tour.rating %> (<%= tour.reviews %> đánh giá)</span>
              </div>

              <div class="tour-foot">
                <div>
                  <% if (tour.originalPrice) { %>
                    <div class="tour-old-price"><%= tour.originalPrice %></div>
                  <% } %>
                  <div class="tour-price"><%= tour.price %></div>
                  <div class="tour-per">/người</div>
                </div>
                <button type="button" class="btn-tour-detail" onclick="event.stopPropagation(); window.location.href='/tour-detail/<%= tour._id %>'">Xem chi tiết</button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="dots" id="tours-dots">
      <% tours.forEach((tour, i) => { %>
        <button class="<%= i === 0 ? 'active' : '' %>"></button>
      <% }) %>
    </div>

    <div class="center-cta">
      <a href="/tour-trong-nuoc" class="btn-gold-gradient" style="text-decoration:none; display:inline-block;">Xem tất cả tour</a>
    </div>
  </div>
</section>
