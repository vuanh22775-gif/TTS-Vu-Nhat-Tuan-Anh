<section class="vbt-hero" id="hero">
  <div class="vbt-hero-bg">
    <img src="https://images.unsplash.com/photo-1561461221-959c3f16234b?w=1920&q=85&auto=format&fit=crop" alt="Vịnh Hạ Long, Quảng Ninh, Việt Nam" />
    <div class="vbt-hero-overlay"></div>
  </div>
  <div class="vbt-hero-frame"></div>

  <div class="vbt-hero-content">
    <div class="vbt-eyebrow">
      <div class="vbt-eyebrow-line l"></div>
      <span>Premium Travel Experience</span>
      <div class="vbt-eyebrow-line r"></div>
    </div>

    <h1 class="vbt-h1">
      Khám Phá thế giới<br />
      <em>Theo Phong Cách Riêng</em>
    </h1>

    <div class="vbt-sep">
      <div class="line"></div>
      <div class="dot"></div>
      <div class="line"></div>
    </div>

    <p class="vbt-hero-sub">
      Hành trình đẳng cấp · Trải nghiệm trọn vẹn · Kỷ niệm vĩnh cửu<br />
      cùng đội ngũ chuyên gia du lịch VIETBLUETOUR
    </p>

    <div class="vbt-search-card">
      <div class="vbt-search-tabs">
        <button class="vbt-search-tab active" data-tab="domestic">Tour Trong Nước</button>
        <button class="vbt-search-tab" data-tab="international">Tour Nước Ngoài</button>
      </div>

      <div class="vbt-search-fields">
        <div class="vbt-field">
          <label>Điểm đến</label>
          <select id="vbt-destination">
            <option value="">Chọn điểm đến...</option>
          </select>
        </div>

        <div class="vbt-field">
          <label>Ngày khởi hành</label>
          <input type="date" id="vbt-departure" />
        </div>

        <div class="vbt-field-guests-search">
          <div class="vbt-field" style="flex:1">
            <label>Hành khách</label>
            <select id="vbt-guests">
              <option>1 người</option>
              <option selected>2 người</option>
              <option>3 người</option>
              <option>4 người</option>
              <option>5+ người</option>
              <option>2 NL + 1 TE</option>
              <option>2 NL + 2 TE</option>
            </select>
          </div>
          <div style="display:flex; align-items:flex-end;">
            <button class="btn-search" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              Tìm
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="vbt-scroll-hint">
      <span>Cuộn xuống</span>
    </div>
  </div>
</section>
