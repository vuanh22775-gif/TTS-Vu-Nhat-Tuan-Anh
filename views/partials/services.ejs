<section id="visa" class="section services-section">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">
        <div class="line l"></div>
        <span>Dịch vụ của chúng tôi</span>
        <div class="line r"></div>
      </div>
      <h2 class="section-title light">Toàn Diện Mọi Nhu Cầu</h2>
      <p class="section-desc light">
        Từ visa đến vé máy bay, từ thuê xe đến chỗ nghỉ — VIETBLUETOUR lo tất cả,
        bạn chỉ cần tận hưởng.
      </p>
    </div>

    <div class="section-divider">
      <div class="line l"></div>
      <div class="dot"></div>
      <div class="line r"></div>
    </div>

    <div class="services-grid">
      <% services.forEach(svc => { %>
        <div class="service-card">
          <div class="service-icon">
            <% if (svc.icon === 'visa') { %>
              <svg width="44" height="44" viewBox="0 0 44 44" fill="none"><rect x="6" y="11" width="32" height="22" rx="3" stroke="#C9A96E" stroke-width="1.5"/><path d="M6 17h32" stroke="#C9A96E" stroke-width="1.5"/><circle cx="22" cy="27" r="4.5" stroke="#C9A96E" stroke-width="1.3"/><path d="M22 24.5v2l1.5 1" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/><path d="M10 24h6M10 28h4" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/><path d="M28 24h6M30 28h4" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/></svg>
            <% } else if (svc.icon === 'car') { %>
              <svg width="44" height="44" viewBox="0 0 44 44" fill="none"><path d="M8 26v-8l4-8h20l4 8v8" stroke="#C9A96E" stroke-width="1.5" stroke-linejoin="round"/><path d="M5 26h34v5H5z" stroke="#C9A96E" stroke-width="1.5"/><circle cx="13" cy="33" r="3" stroke="#C9A96E" stroke-width="1.4"/><circle cx="31" cy="33" r="3" stroke="#C9A96E" stroke-width="1.4"/><path d="M16 33h12M5 22h34" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/><path d="M12 18h8M24 18h8" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/></svg>
            <% } else if (svc.icon === 'flight') { %>
              <svg width="44" height="44" viewBox="0 0 44 44" fill="none"><path d="M7 32l6-4 22-14 2-2a3 3 0 00-4.24-4.24l-2 2L17 32" stroke="#C9A96E" stroke-width="1.5" stroke-linejoin="round"/><path d="M7 32l6-4 4 4-4 3-6-3z" stroke="#C9A96E" stroke-width="1.3" stroke-linejoin="round"/><path d="M20 19l5 5M31 11l2 5-5-2" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 37h28" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/></svg>
            <% } else { %>
              <svg width="44" height="44" viewBox="0 0 44 44" fill="none"><path d="M7 22L22 9l15 13" stroke="#C9A96E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11 19v14h22V19" stroke="#C9A96E" stroke-width="1.5" stroke-linejoin="round"/><rect x="17" y="26" width="10" height="7" rx="1.5" stroke="#C9A96E" stroke-width="1.3"/><rect x="14" y="21" width="6" height="5" rx="1" stroke="#C9A96E" stroke-width="1.2"/><rect x="24" y="21" width="6" height="5" rx="1" stroke="#C9A96E" stroke-width="1.2"/><path d="M22 9V6" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/></svg>
            <% } %>
          </div>
          <h3 class="service-title"><%= svc.title %></h3>
          <p class="service-desc"><%= svc.desc %></p>
          <a href="<%= svc.href %>" class="service-link">
            Tìm hiểu thêm
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 4l4 3-4 3" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</section>
