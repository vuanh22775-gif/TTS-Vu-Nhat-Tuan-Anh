<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/header') %>

  <main>
    <div class="booking-success-wrap" style="margin-top: 76px;">
      <div class="booking-success-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h1>Đặt Tour Thành Công!</h1>
      <p>Cảm ơn <%= booking.customerName %> đã tin tưởng VIETBLUETOUR. Chúng tôi sẽ liên hệ xác nhận trong vòng 24h.</p>

      <div class="booking-success-card">
        <div class="booking-success-code">Mã đặt tour: <%= booking.bookingCode %></div>

        <div class="booking-success-row">
          <span>Tour</span>
          <span><%= booking.tourName %></span>
        </div>
        <div class="booking-success-row">
          <span>Ngày khởi hành</span>
          <span><%= new Date(booking.departureDate).toLocaleDateString('vi-VN') %></span>
        </div>
        <div class="booking-success-row">
          <span>Số lượng khách</span>
          <span><%= booking.numberOfGuests %> người</span>
        </div>
        <div class="booking-success-row">
          <span>Số điện thoại</span>
          <span><%= booking.customerPhone %></span>
        </div>
        <% if (booking.customerEmail) { %>
        <div class="booking-success-row">
          <span>Email</span>
          <span><%= booking.customerEmail %></span>
        </div>
        <% } %>
        <div class="booking-success-row">
          <span>Tổng tiền</span>
          <span><%= formatPrice(booking.totalPrice) %></span>
        </div>
        <div class="booking-success-row">
          <span>Trạng thái</span>
          <span style="color: var(--gold-dark);">Chờ xác nhận</span>
        </div>
      </div>

      <div class="booking-success-actions">
        <a href="/" class="btn-success-primary">Về Trang Chủ</a>
        <a href="tel:0969691889" class="btn-success-outline">📞 Gọi Hotline</a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
