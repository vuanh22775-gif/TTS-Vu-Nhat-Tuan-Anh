  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const typeBtns = document.querySelectorAll('.type-btn');
      const regionTabs = document.querySelectorAll('.region-tab');
      const homestayCards = document.querySelectorAll('.homestay-card');

      function filterCards() {
        const selectedType = Array.from(typeBtns).find(b => b.classList.contains('active'))?.dataset.type || 'all';
        const selectedRegion = Array.from(regionTabs).find(t => t.classList.contains('active'))?.dataset.region || 'all';

        homestayCards.forEach(card => {
          const cardType = card.dataset.type;
          const cardRegion = card.dataset.region;

          const typeMatch = selectedType === 'all' || cardType === selectedType;
          const regionMatch = selectedRegion === 'all' || cardRegion === selectedRegion;

          card.style.display = typeMatch && regionMatch ? '' : 'none';
        });
      }

      typeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          typeBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          filterCards();
        });
      });

      regionTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          regionTabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          filterCards();
        });
      });
    });
  </script>
</body>
</html>
