          <div class="homestay-types">
            <button class="type-btn active" data-type="all">Tất Cả</button>
            <button class="type-btn" data-type="homestay">Homestay</button>
            <button class="type-btn" data-type="villa">Villa</button>
          </div>
        </div>

        <!-- Region Filter -->
