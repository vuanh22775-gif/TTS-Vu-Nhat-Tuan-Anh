<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .homestay-filter { padding: 32px 0; background: #fff; }
    .homestay-types { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; justify-content: center; }
    .type-btn { padding: 10px 20px; border-radius: 20px; border: 1.5px solid var(--green); 
                background: transparent; color: var(--green); font-size: 13px; font-weight: 500; 
                cursor: pointer; transition: all .2s; }
    .type-btn.active { background: var(--green); color: #fff; }
    .region-tabs { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
    .region-tab { padding: 8px 16px; border-radius: 20px; border: 1px solid #E8E4DC; background: #fff; 
                  color: #666; font-size: 13px; cursor: pointer; transition: all .2s; }
    .region-tab.active { background: var(--green); color: #fff; border-color: var(--green); }

    .homestay-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .homestay-card { border-radius: 16px; overflow: hidden; background: #fff; border: 1px solid #E8E4DC; 
                     transition: all .3s; display: flex; flex-direction: column; }
    .homestay-card:hover { box-shadow: 0 15px 40px rgba(4,97,72,.15); transform: translateY(-5px); }
    
    .homestay-image { position: relative; aspect-ratio: 4/3; overflow: hidden; background: #E8E4DC; }
    .homestay-image img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; }
    .homestay-card:hover .homestay-image img { transform: scale(1.08); }
    
    .homestay-badge { position: absolute; top: 12px; left: 12px; padding: 4px 12px; border-radius: 20px; 
                      background: rgba(0,0,0,.6); color: #fff; font-size: 11px; font-weight: 600; 
                      display: flex; align-items: center; gap: 4px; }
    
    .homestay-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
    .homestay-type { font-size: 11px; color: var(--gold); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 6px; }
    .homestay-name { font-family: var(--font-serif); font-size: 18px; font-weight: 600; color: #1A1A1A; 
                     margin: 0 0 8px; line-height: 1.35; }
    .homestay-location { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #999; margin-bottom: 12px; }
    .homestay-location svg { color: var(--gold); flex-shrink: 0; }
    
    .homestay-specs { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 16px; font-size: 12px; }
    .spec-item { display: flex; flex-direction: column; align-items: center; text-align: center; }
    .spec-value { font-weight: 600; color: #1A1A1A; margin-bottom: 2px; }
    .spec-label { color: #999; font-size: 11px; }
    
    .homestay-rating { display: flex; align-items: center; gap: 6px; margin-bottom: 16px; font-size: 13px; }
    .homestay-rating .stars { display: flex; gap: 2px; color: var(--gold); }
    
    .homestay-price { display: flex; align-items: baseline; gap: 6px; margin-bottom: 16px; }
    .homestay-price-value { font-family: var(--font-serif); font-size: 20px; font-weight: 700; color: var(--green); }
    .homestay-price-per { font-size: 12px; color: #A0A0A0; }
    
    .homestay-amenities { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; font-size: 12px; }
    .amenity { display: flex; align-items: center; gap: 6px; color: #666; }
    .amenity svg { width: 12px; height: 12px; color: var(--gold); flex-shrink: 0; }
    
    .homestay-buttons { display: flex; gap: 8px; margin-top: auto; }
    .btn-view { flex: 1; padding: 10px; border-radius: 8px; background: var(--green); color: #fff; 
                font-size: 12px; font-weight: 600; cursor: pointer; transition: all .2s; border: none; }
    .btn-view:hover { background: var(--green-mid); transform: translateY(-2px); }
    .btn-contact { flex: 1; padding: 10px; border-radius: 8px; background: transparent; 
                   border: 1.5px solid var(--green); color: var(--green); font-size: 12px; 
                   font-weight: 600; cursor: pointer; transition: all .2s; }
    .btn-contact:hover { background: var(--green); color: #fff; }
  </style>
</head>
<body>

  <%- include('partials/header') %>

  <main>
