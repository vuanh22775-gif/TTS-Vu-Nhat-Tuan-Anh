<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Manage Tours</title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    body { background: #F5F5F5; }
.admin-container {
    display: grid;
    grid-template-columns: 260px 1fr;
    grid-template-rows: auto 1fr;
    min-height: 100vh;
}

.admin-sidebar {
    grid-row: 1 / 3;
    grid-column: 1;
    background: linear-gradient(135deg, #046148 0%, #054d3a 100%);
    color: #fff;
    padding: 24px;
}

.admin-header {
    grid-column: 2;
    grid-row: 1;
    background: #fff;
    padding: 16px 24px;
    border-bottom: 1px solid #E8E4DC;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.admin-main {
    grid-column: 2;
    grid-row: 2;
    padding: 32px;
}    .admin-header h2 { margin: 0; color: var(--green); font-size: 20px; font-family: var(--font-serif); }
    .sidebar-nav { list-style: none; padding: 0; margin: 24px 0 0; display: flex; flex-direction: column; gap: 8px; }
    .sidebar-nav li a { display: block; padding: 12px 16px; color: rgba(255,255,255,.7); border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 500; transition: all .2s; }
    .sidebar-nav li a:hover { background: rgba(255,255,255,.1); color: #fff; }
    .sidebar-nav li a.active { background: #C9A96E; color: var(--green); }

    .admin-header-actions { display: flex; gap: 12px; align-items: center; }
    .btn-admin { padding: 10px 16px; background: var(--green); color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 13px; transition: all .2s; }
    .btn-admin:hover { background: var(--green-mid); transform: translateY(-2px); }
    .btn-admin.secondary { background: transparent; border: 1px solid #E8E4DC; color: #666; }
    .btn-admin.secondary:hover { background: #FAF8F4; color: var(--green); }

    .admin-table { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
    .admin-table table { width: 100%; border-collapse: collapse; }
    .admin-table th { background: #FAF8F4; padding: 16px; text-align: left; font-size: 12px; text-transform: uppercase; font-weight: 600; color: #666; border-bottom: 1px solid #E8E4DC; }
    .admin-table td { padding: 16px; border-bottom: 1px solid #E8E4DC; font-size: 13px; }
    .admin-table tr:hover { background: #FAF8F4; }
    
    .action-btn { padding: 6px 12px; border: 1px solid #E8E4DC; background: transparent; border-radius: 6px; cursor: pointer; font-size: 11px; margin-right: 8px; transition: all .2s; }
    .action-btn:hover { background: #FAF8F4; color: var(--green); border-color: var(--green); }
    .action-btn.delete { border-color: #dc3545; color: #dc3545; }
    .action-btn.delete:hover { background: rgba(220,53,69,.1); }

    .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.5); z-index: 1000; align-items: center; justify-content: center; }
    .modal.show { display: flex; }
    .modal-content { background: #fff; border-radius: 12px; padding: 32px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .modal-header h2 { margin: 0; color: var(--green); font-size: 20px; }
    .modal-close { background: none; border: none; font-size: 24px; cursor: pointer; color: #999; }
    .form-group { margin-bottom: 16px; display: flex; flex-direction: column; }
    .form-group label { font-size: 12px; text-transform: uppercase; color: #666; font-weight: 600; margin-bottom: 8px; }
    .form-group input, .form-group select, .form-group textarea { padding: 10px; border: 1px solid #E8E4DC; border-radius: 6px; font-size: 13px; font-family: var(--font-sans); }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--gold); outline: none; }
    .form-actions { display: flex; gap: 12px; margin-top: 24px; }
    .form-actions button { flex: 1; padding: 12px; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; }

    .section-title { margin-bottom: 20px; color: #1A1A1A; font-size: 18px; font-weight: 600; }
    @media (max-width: 768px) {
    .admin-container {
        grid-template-columns: 1fr;
    }

    .admin-sidebar {
        display: none;
    }

    .admin-header,
    .admin-main {
        grid-column: 1;
    }
}
  </style>
</head>
<body>

  <div class="admin-container">
    <!-- Sidebar -->
    <%- include('partials/sidebar', { active: 'tours' }) %>

    <!-- Header -->
    <header class="admin-header">
      <h2>Manage Tours</h2>
      <div class="admin-header-actions">
        <button class="btn-admin" onclick="openAddTourModal()">+ Add New Tour</button>
        <a href="/admin/logout" class="btn-admin secondary">Đăng Xuất</a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="admin-main">
      <% if (typeof dbConnected !== 'undefined' && !dbConnected) { %>
        <div class="db-warning">⚠️ Chưa kết nối được MongoDB. Kiểm tra biến <code>MONGODB_URI</code> trong file <code>.env</code> rồi khởi động lại server.</div>
      <% } %>
      <h1 style="margin: 0 0 32px; color: #1A1A1A; font-size: 24px; font-weight: 700;">Tours Management</h1>

      <div class="admin-table">
        <table>
          <thead>
            <tr>
              <th>Tour Name</th>
              <th>Type</th>
              <th>Price</th>
              <th>Duration</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (tours && tours.length > 0) { %>
              <% tours.forEach(tour => { %>
                <tr>
                  <td><strong><%= tour.name %></strong></td>
                  <td><span style="color: var(--gold); font-size: 11px; text-transform: uppercase; font-weight: 600;">
                    <%= tour.type === 'domestic' ? 'Trong nước' : 'Nước ngoài' %>
                  </span></td>
                  <td><%= tour.price %></td>
                  <td><%= tour.duration %></td>
                  <td><span style="padding: 4px 12px; background: rgba(4,97,72,.1); color: var(--green); border-radius: 20px; font-size: 11px; font-weight: 600;">Active</span></td>
                  <td>
                    <button class="action-btn" onclick="editTour('<%= tour._id %>')">Edit</button>
                    <form method="POST" action="/admin/tours/<%= tour._id %>/delete" style="display:inline;" onsubmit="return confirm('Xoá tour này?');">
                      <button type="submit" class="action-btn delete">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align: center; color: #999; padding: 32px;">Không có tour nào. <a href="#" onclick="openAddTourModal()" style="color: var(--green);">Thêm tour mới</a></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </main>
  </div>

  <!-- Add/Edit Tour Modal -->
  <div class="modal" id="tourModal">
    <div class="modal-content">
      <div class="modal-header">
        <h2 id="modalTitle">Add New Tour</h2>
        <button class="modal-close" onclick="closeTourModal()">✕</button>
      </div>

      <form id="tourForm" method="POST" action="/admin/tours">
        <div class="form-group">
          <label>Tour Name *</label>
          <input type="text" name="name" required>
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea name="description"></textarea>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div class="form-group">
            <label>Type *</label>
            <select name="type" required>
              <option value="">-- Select Type --</option>
              <option value="domestic">Domestic</option>
              <option value="international">International</option>
            </select>
          </div>

          <div class="form-group">
            <label>Price (₫) *</label>
            <input type="number" name="price" min="0" required>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div class="form-group">
            <label>Duration (days) *</label>
            <input type="number" name="duration" min="1" required>
          </div>

          <div class="form-group">
            <label>Location</label>
            <input type="text" name="location">
          </div>
        </div>

        <div class="form-group">
          <label>Image URL</label>
          <input type="url" name="image">
        </div>

        <div class="form-actions">
          <button type="button" class="btn-admin secondary" style="flex: 1;" onclick="closeTourModal()">Cancel</button>
          <button type="submit" class="btn-admin" style="flex: 1;">Save Tour</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openAddTourModal() {
      document.getElementById('modalTitle').textContent = 'Add New Tour';
      document.getElementById('tourForm').reset();
      document.getElementById('tourForm').action = '/admin/tours';
      document.getElementById('tourModal').classList.add('show');
    }

    function closeTourModal() {
      document.getElementById('tourModal').classList.remove('show');
    }

    function editTour(id) {
      alert('Chức năng chỉnh sửa sẽ sớm được bổ sung. Hiện tại bạn có thể xoá và tạo lại tour.');
    }

    // Close modal when clicking outside
    document.getElementById('tourModal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('tourModal')) {
        closeTourModal();
      }
    });
  </script>
</body>
</html>
