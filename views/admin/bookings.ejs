<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Manage Bookings</title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    body { background: #F5F5F5; }
.admin-container {
    display: grid;
    grid-template-columns: 260px 1fr;
    grid-template-rows: auto 1fr;
    min-height: 100vh;
}

.admin-sidebar {
    grid-row: 1 / 3;
    grid-column: 1;
    background: linear-gradient(135deg, #046148 0%, #054d3a 100%);
    color: #fff;
    padding: 24px;
}

.admin-header {
    grid-column: 2;
    grid-row: 1;
    background: #fff;
    padding: 16px 24px;
    border-bottom: 1px solid #E8E4DC;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.admin-main {
    grid-column: 2;
    grid-row: 2;
    padding: 32px;
}
   .sidebar-nav { list-style: none; padding: 0; margin: 24px 0 0; display: flex; flex-direction: column; gap: 8px; }
    .sidebar-nav li a { display: block; padding: 12px 16px; color: rgba(255,255,255,.7); border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 500; transition: all .2s; }
    .sidebar-nav li a:hover { background: rgba(255,255,255,.1); color: #fff; }
    .sidebar-nav li a.active { background: #C9A96E; color: var(--green); }
    .admin-table { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
    .admin-table table { width: 100%; border-collapse: collapse; }
    .admin-table th { background: #FAF8F4; padding: 16px; text-align: left; font-size: 12px; text-transform: uppercase; font-weight: 600; color: #666; border-bottom: 1px solid #E8E4DC; }
    .admin-table td { padding: 16px; border-bottom: 1px solid #E8E4DC; font-size: 13px; }
    .status-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .status-confirmed { background: rgba(4,97,72,.1); color: var(--green); }
    .status-pending { background: rgba(201,169,110,.1); color: var(--gold); }
    .status-cancelled { background: rgba(220,53,69,.1); color: #dc3545; }
    .action-btn { padding: 6px 12px; border: 1px solid #E8E4DC; background: transparent; border-radius: 6px; cursor: pointer; font-size: 11px; margin-right: 8px; transition: all .2s; }
    .action-btn:hover { background: #FAF8F4; color: var(--green); border-color: var(--green); }
    @media (max-width: 768px) {
    .admin-container {
        grid-template-columns: 1fr;
    }

    .admin-sidebar {
        display: none;
    }

    .admin-header,
    .admin-main {
        grid-column: 1;
    }
}
  </style>
</head>
<body>

  <div class="admin-container">
    <!-- Sidebar -->
    <%- include('partials/sidebar', { active: 'bookings' }) %>

    <!-- Header -->
    <header class="admin-header">
      <h2>Manage Bookings</h2>
      <a href="/admin/logout" style="padding: 10px 16px; background: var(--gold); color: var(--green); border: none; border-radius: 6px; cursor: pointer; font-weight: 600; text-decoration: none;">Đăng Xuất</a>
    </header>

    <!-- Main Content -->
    <main class="admin-main">
      <% if (typeof dbConnected !== 'undefined' && !dbConnected) { %>
        <div class="db-warning">⚠️ Chưa kết nối được MongoDB. Kiểm tra biến <code>MONGODB_URI</code> trong file <code>.env</code> rồi khởi động lại server.</div>
      <% } %>
      <h1 style="margin: 0 0 32px; color: #1A1A1A; font-size: 24px; font-weight: 700;">Bookings Management</h1>

      <div class="admin-table">
        <table>
          <thead>
            <tr>
              <th>Booking Code</th>
              <th>Customer</th>
              <th>Tour</th>
              <th>Date</th>
              <th>Price</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (bookings && bookings.length > 0) { %>
              <% bookings.forEach(booking => { %>
                <tr>
                  <td><strong><%= booking.bookingCode %></strong></td>
                  <td><%= booking.customerName %></td>
                  <td><%= booking.tourName %></td>
                  <td><%= new Date(booking.departureDate).toLocaleDateString('vi-VN') %></td>
                  <td><%= booking.totalPrice.toLocaleString('vi-VN') %>₫</td>
                  <td><span class="status-badge status-<%= booking.status %>"><%= booking.status %></span></td>
                  <td>
                    <form method="POST" action="/admin/bookings/<%= booking._id %>/status" style="display:flex; gap:6px; align-items:center;">
                      <select name="status" onchange="this.form.submit()" style="padding:6px 8px; border:1px solid #E8E4DC; border-radius:6px; font-size:11px;">
                        <option value="pending" <%= booking.status === 'pending' ? 'selected' : '' %>>Chờ xác nhận</option>
                        <option value="confirmed" <%= booking.status === 'confirmed' ? 'selected' : '' %>>Đã xác nhận</option>
                        <option value="cancelled" <%= booking.status === 'cancelled' ? 'selected' : '' %>>Đã huỷ</option>
                      </select>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="7" style="text-align: center; color: #999;">Không có dữ liệu</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </main>
  </div>

</body>
</html>
