<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="description" content="Đặt tour <%= tour.name %> nhanh chóng, an toàn cùng VIETBLUETOUR." />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/header') %>

  <main>
    <div class="page-header-hero">
      <div class="container">
        <h1>Đặt Tour</h1>
        <p><%= tour.name %> • <%= tour.location %></p>
      </div>
    </div>

    <section class="booking-section">
      <div class="container">
        <div class="booking-grid">
          <!-- Form -->
          <div class="booking-form-box">
            <h2>Thông Tin Đặt Tour</h2>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="form-error"><%= error %></div>
            <% } %>

            <form method="POST" action="/dat-tour/<%= tour._id %>">
              <div class="form-row two-col">
                <div class="form-group">
                  <label>Họ và tên <span class="req">*</span></label>
                  <input type="text" name="customerName" placeholder="Nguyễn Văn A" required value="<%= (typeof old !== 'undefined' && old.customerName) ? old.customerName : '' %>">
                </div>
                <div class="form-group">
                  <label>Số điện thoại <span class="req">*</span></label>
                  <input type="tel" name="customerPhone" placeholder="09xx xxx xxx" required value="<%= (typeof old !== 'undefined' && old.customerPhone) ? old.customerPhone : '' %>">
                </div>
              </div>

              <div class="form-row two-col">
                <div class="form-group">
                  <label>Email</label>
                  <input type="email" name="customerEmail" placeholder="email@example.com" value="<%= (typeof old !== 'undefined' && old.customerEmail) ? old.customerEmail : '' %>">
                </div>
                <div class="form-group">
                  <label>Số lượng khách <span class="req">*</span></label>
                  <input type="number" id="numberOfGuests" name="numberOfGuests" min="1" value="<%= (typeof old !== 'undefined' && old.numberOfGuests) ? old.numberOfGuests : 1 %>" required>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Ngày khởi hành dự kiến <span class="req">*</span></label>
                  <input type="date" name="departureDate" required value="<%= (typeof old !== 'undefined' && old.departureDate) ? old.departureDate : '' %>">
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label>Ghi chú</label>
                  <textarea name="notes" rows="4" placeholder="Yêu cầu đặc biệt (nếu có)..."><%= (typeof old !== 'undefined' && old.notes) ? old.notes : '' %></textarea>
                </div>
              </div>

              <button type="submit" class="btn-book-now" style="margin-top: 8px;">Xác Nhận Đặt Tour</button>
              <p style="font-size: 12px; color: #999; text-align: center; margin-top: 12px;">
                Sau khi đặt, nhân viên VIETBLUETOUR sẽ liên hệ xác nhận trong vòng 24h.
              </p>
            </form>
          </div>

          <!-- Summary -->
          <div class="booking-summary-box">
            <h3>Tóm Tắt Đơn Hàng</h3>
            <div class="booking-summary-tour">
              <img src="<%= tour.image %>" alt="<%= tour.name %>" onerror="this.src='https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=200&h=150&fit=crop'">
              <div>
                <strong><%= tour.name %></strong>
                <p><%= tour.location %></p>
                <p><%= tour.duration %></p>
              </div>
            </div>

            <div class="booking-summary-line">
              <span>Đơn giá / người</span>
              <span id="unit-price-display"><%= tour.price %></span>
            </div>
            <div class="booking-summary-line">
              <span>Số lượng khách</span>
              <span id="guests-display"><%= (typeof old !== 'undefined' && old.numberOfGuests) ? old.numberOfGuests : 1 %></span>
            </div>

            <div class="booking-summary-total">
              <span>Tổng cộng</span>
              <span id="total-price-display"><%= formatPrice(unitPriceNumber * ((typeof old !== 'undefined' && old.numberOfGuests) ? old.numberOfGuests : 1)) %></span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script>
    // Cập nhật tổng tiền theo số lượng khách (client-side, để trải nghiệm mượt hơn)
    (function () {
      const unitPrice = <%= unitPriceNumber %>;
      const guestsInput = document.getElementById('numberOfGuests');
      const guestsDisplay = document.getElementById('guests-display');
      const totalDisplay = document.getElementById('total-price-display');

      function formatVND(n) {
        return n.toLocaleString('vi-VN') + '₫';
      }

      guestsInput?.addEventListener('input', () => {
        const guests = Math.max(1, parseInt(guestsInput.value, 10) || 1);
        guestsDisplay.textContent = guests;
        totalDisplay.textContent = formatVND(unitPrice * guests);
      });
    })();
  </script>
</body>
</html>
