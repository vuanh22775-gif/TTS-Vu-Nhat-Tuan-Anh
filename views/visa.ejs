<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .visa-section { padding: 96px 0; background: #fff; }
    .visa-tabs { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 48px; border-bottom: 2px solid #E8E4DC; }
    .visa-tab { padding: 14px 24px; border: none; background: transparent; font-size: 14px; font-weight: 500; 
                color: #999; cursor: pointer; border-bottom: 2px solid transparent; transition: all .2s; }
    .visa-tab.active { color: var(--green); border-bottom-color: var(--green); }
    .visa-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; }
    .visa-card { border-radius: 16px; overflow: hidden; background: #fff; border: 1px solid #E8E4DC; 
                 transition: all .3s; padding: 24px; }
    .visa-card:hover { box-shadow: 0 10px 30px rgba(4,97,72,.12); transform: translateY(-4px); border-color: var(--gold); }
    .visa-country { font-size: 13px; color: var(--gold); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
    .visa-title { font-family: var(--font-serif); font-size: 20px; font-weight: 600; color: #1A1A1A; margin: 0 0 12px; }
    .visa-info { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 20px 0; font-size: 14px; }
    .visa-info-item { }
    .visa-info-label { color: #999; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
    .visa-info-value { color: #1A1A1A; font-weight: 500; }
    .visa-documents { margin: 20px 0; }
    .visa-documents h4 { color: #1A1A1A; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; margin: 0 0 12px; }
    .visa-documents ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
    .visa-documents li { display: flex; align-items: flex-start; gap: 8px; color: #666; font-size: 13px; }
    .visa-documents li::before { content: '✓'; color: var(--gold); font-weight: bold; flex-shrink: 0; }
    .visa-cta { display: flex; gap: 12px; margin-top: 20px; }
    .visa-cta button { flex: 1; padding: 12px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; 
                       transition: all .2s; border: none; }
    .visa-consult { background: linear-gradient(135deg, var(--green), var(--green-mid)); color: #fff; }
    .visa-consult:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(4,97,72,.25); }
  </style>
</head>
<body>

  <%- include('partials/header') %>

  <main>
    <!-- Page Header -->
    <div class="page-header-hero">
      <div class="container">
        <h1>Dịch Vụ Visa</h1>
        <p>Xin visa nhanh chóng, chuyên nghiệp trên 50+ quốc gia</p>
      </div>
    </div>

    <!-- Visa Services -->
    <section class="visa-section">
      <div class="container">
        <div style="text-align: center; margin-bottom: 64px;">
          <div class="section-eyebrow" style="justify-content: center; margin-bottom: 20px;">
            <div class="line l"></div>
            <span>Dịch vụ visa</span>
            <div class="line r"></div>
          </div>
          <h2 class="section-title">Xin Visa Du Lịch Toàn Cầu</h2>
          <p class="section-desc">Chúng tôi hỗ trợ xin visa nhanh chóng, tỷ lệ thành công cao. 
            Đội ngũ chuyên gia sẽ hướng dẫn hồ sơ từ A-Z.</p>
        </div>

        <!-- Tabs -->
        <div class="visa-tabs">
          <button class="visa-tab active" data-region="asia">Châu Á</button>
          <button class="visa-tab" data-region="europe">Châu Âu</button>
          <button class="visa-tab" data-region="americas">Châu Mỹ</button>
          <button class="visa-tab" data-region="oceania">Châu Úc</button>
        </div>

        <!-- Visa Grid -->
        <div class="visa-grid" id="visa-list">
