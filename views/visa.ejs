              </div>
              <div class="visa-info-item">
                <div class="visa-info-label">Giá Dịch Vụ</div>
                <div class="visa-info-value" style="color: var(--green); font-weight: 700;">1.200.000₫</div>
              </div>
            </div>

            <div class="visa-documents">
              <h4>Hồ Sơ Cần Thiết</h4>
              <ul>
                <li>Hộ chiếu còn hiệu lực tối thiểu 6 tháng</li>
                <li>2 ảnh 4x6 cm nền trắng</li>
                <li>Giấy xác nhận tài chính</li>
                <li>Vé máy bay</li>
                <li>Booking khách sạn</li>
              </ul>
            </div>

            <div class="visa-cta">
              <button class="visa-consult">Tư Vấn Ngay</button>
            </div>
          </div>

          <div class="visa-card">
            <div class="visa-country">Singapore</div>
            <h3 class="visa-title">Visa Du Lịch Singapore</h3>
            
            <div class="visa-info">
              <div class="visa-info-item">
                <div class="visa-info-label">Thời Gian Xử Lý</div>
                <div class="visa-info-value">5-7 ngày</div>
              </div>
              <div class="visa-info-item">
                <div class="visa-info-label">Giá Dịch Vụ</div>
                <div class="visa-info-value" style="color: var(--green); font-weight: 700;">1.500.000₫</div>
              </div>
            </div>

            <div class="visa-documents">
              <h4>Hồ Sơ Cần Thiết</h4>
              <ul>
                <li>Hộ chiếu còn hiệu lực tối thiểu 6 tháng</li>
                <li>2 ảnh 4x6 cm nền trắng</li>
                <li>Giấy xác nhận tài chính</li>
                <li>Vé máy bay</li>
                <li>Booking khách sạn</li>
              </ul>
            </div>

            <div class="visa-cta">
              <button class="visa-consult">Tư Vấn Ngay</button>
            </div>
          </div>

          <div class="visa-card">
            <div class="visa-country">Nhật Bản</div>
            <h3 class="visa-title">Visa Du Lịch Nhật Bản</h3>
            
            <div class="visa-info">
              <div class="visa-info-item">
                <div class="visa-info-label">Thời Gian Xử Lý</div>
