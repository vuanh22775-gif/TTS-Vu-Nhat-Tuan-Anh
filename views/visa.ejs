            </div>

            <div class="visa-cta">
              <button class="visa-consult">Tư Vấn Ngay</button>
            </div>
          </div>

          <div class="visa-card">
            <div class="visa-country">Mỹ</div>
            <h3 class="visa-title">Visa Du Lịch Mỹ</h3>
            
            <div class="visa-info">
              <div class="visa-info-item">
                <div class="visa-info-label">Thời Gian Xử Lý</div>
                <div class="visa-info-value">15-30 ngày</div>
              </div>
              <div class="visa-info-item">
                <div class="visa-info-label">Giá Dịch Vụ</div>
                <div class="visa-info-value" style="color: var(--green); font-weight: 700;">3.200.000₫</div>
              </div>
            </div>

            <div class="visa-documents">
              <h4>Hồ Sơ Cần Thiết</h4>
              <ul>
                <li>Hộ chiếu còn hiệu lực tối thiểu 6 tháng</li>
                <li>2 ảnh 5x5 cm</li>
                <li>Đơn xin visa DS-160</li>
                <li>Giấy xác nhận tài chính</li>
                <li>Thư mời (nếu có)</li>
              </ul>
            </div>

            <div class="visa-cta">
              <button class="visa-consult">Tư Vấn Ngay</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <%- include('partials/cta') %>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.visa-tab');
      const consultBtns = document.querySelectorAll('.visa-consult');
      
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          // Filter visa cards by region - demo only
          alert('Đang hiển thị: ' + tab.textContent);
        });
      });

      consultBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          alert('Vui lòng gọi hotline: 0969 691 889 để được tư vấn visa');
        });
      });
    });
  </script>
</body>
</html>
