              </div>
              <div class="visa-info-item">
                <div class="visa-info-label">Giá Dịch Vụ</div>
                <div class="visa-info-value" style="color: var(--green); font-weight: 700;">3.500.000₫</div>
              </div>
            </div>

            <div class="visa-documents">
              <h4>Hồ Sơ Cần Thiết</h4>
